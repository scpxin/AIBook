# ============================================================
# Fanqie Novel Creator V2 — 环境变量配置模板
# ============================================================
# 复制此文件为 .env 并根据实际环境修改
#     cp .env.example .env
# ============================================================

# --- 必填: AI 模型配置 ---
AI_ENDPOINT=https://api.longcat.chat/openai
AI_API_KEY=your-api-key-here
AI_MODEL=LongCat-2.0
AI_TIMEOUT=600
AI_VERIFY_SSL=true

# --- 服务器配置 ---
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:80

# --- 数据库 ---
DB_PATH=fanqie.db

# --- 数据目录 ---
DOWNLOAD_DIR=/app/data/downloads
PROJECTS_DIR=/app/data/projects
LOG_DIR=/app/data/logs

# --- 外部 API ---
CONTENT_API=http://localhost:5000/api/content?tab=%E5%B0%8F%E8%AF%B4&item_id={}
SEARCH_API=https://novel.snssdk.com/api/novel/channel/homepage/search/search/v1/?aid=1967&q={}&offset=0
DIR_API=https://novel.snssdk.com/api/novel/book/directory/detail/v1/?aid=1967&book_id={}
UA=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# --- 代理安全 ---
ALLOWED_PROXY_DOMAINS=

# --- 会话 ---
SESSION_TTL=86400
HTTP_TIMEOUT=30
MAX_BODY_SIZE=52428800
